---
import '../styles/global.css';
// SS_Portfolio Data
const name = "Shishu Fujishiro";
const jpName = "藤白 詩集";
const roles = "Compositor / Colorist / Motion Designer / Cinematographer";
const email = "info@corecreative.jp";

const snsLinks = [
  { name: "X (Twitter)", url: "https://x.com/cumuloworks" },
];

const logs = [
  { date: "2025.12.21.", content: "V/R Converters「ニューラルへ縹緲」オフィシャルリリックブック", url: "https://x.com/shiro_works/status/2003103881790914873?s=20" },
  { date: "2025.12.12.", content: "【 # 4 生演奏歌枠 】manuscript / 綿菓子かんろ", url: "https://x.com/Wata_kanro/status/1999463442328224198?s=20" },
  { date: "2025.09.01.", content: "Core Creative 加入 / CDs 加入 / 名義追加", url: "https://x.com/shiro_works/status/1962168505782186124?s=20" },
  { date: "2025.08.22.", content: "【#3 生演奏歌枠】常夏ノ夜ニ萌ユ！", url: "https://x.com/Wata_kanro/status/1958875429101871257?s=20" },
  { date: "2025.08.16.", content: "【歌ってみた】空想フォレスト / 綿菓子かんろ", url: "https://x.com/Wata_kanro/status/1956371845164253453?s=20" },
  { date: "2025.07.25.", content: "【歌ってみた】サンフェーデッド / 綿菓子かんろ", url: "https://x.com/shiro_works/status/1961069976883782057?s=20." },
  { date: "2025.03.06.", content: "【歌ってみた】きゅびずむ / 綿菓子かんろ", url: "https://x.com/Wata_kanro/status/1897624776644124810?s=20" },
];

const workScope = [
  { title: "Music Video", desc: "Filmmaking / Editing / Motion Graphics" },
  { title: "Film Instructor", desc: "Support Lecturer at Vocational School" },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SS_Portfolio | {name}</title>
    <style is:global>
      /* --- Rotary Setting --- */
      .rotary-viewport {
        height: 320px;
        overflow-y: auto;
        scroll-snap-type: y mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
        mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
      }
      .rotary-viewport::-webkit-scrollbar { display: none; }
      .rotary-item { height: 80px; display: flex; align-items: center; scroll-snap-align: center; }

      /* --- Focus Dim Effect --- */
      .focus-container { transition: opacity 0.5s ease; }
      /* リンクにホバーした時、それ以外のテキストの不透明度を下げる */
      .focus-container:has(a:hover) p { opacity: 0.2; }
      .focus-container:has(a:hover) a:not(:hover) { opacity: 0.2; }
      .focus-container p, .focus-container a { transition: opacity 0.3s ease; }

      /* --- Cursor Follower --- */
      #cursor-light {
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, rgba(208,226,248,0.15) 0%, transparent 70%);
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        mix-blend-mode: screen;
        transition: transform 0.1s ease-out;
        display: none;
      }
      @media (hover: hover) { #cursor-light { display: block; } }
    </style>
  </head>
  <body class="bg-[#0a0a0a] text-[#a1a1a1] font-sans selection:bg-white selection:text-black antialiased overflow-x-hidden">
    
    <div id="cursor-light"></div>

    <div class="max-w-6xl mx-auto p-6 md:p-16 lg:p-24 min-h-screen flex flex-col relative z-10">
      
      <header class="flex justify-between items-start mb-32">
        <div class="text-[10px] tracking-[0.4em] font-black text-white uppercase opacity-50">SS_Portfolio v2.3</div>
        <div class="text-[10px] tracking-widest uppercase font-mono text-right space-y-1">
          <div>Status: <span class="text-green-500 animate-pulse">ONLINE</span></div>
          <div id="sys-time" class="text-zinc-500">TIME: --:--:--</div>
          <div id="load-time" class="text-zinc-600">LOAD: ---ms</div>
        </div>
      </header>

      <main class="flex-grow">
        <section class="mb-20">
          <div class="border-b border-zinc-900 pb-8 mb-12">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4 transition-all duration-700 hover:tracking-widest cursor-default">
              {name}
              <span class="text-zinc-600 font-light text-xl md:text-2xl italic ml-4 tracking-normal">{jpName}</span>
            </h1>

            <div class="focus-container space-y-10 text-sm md:text-base leading-relaxed max-w-3xl font-light">
              <div>
                <p class="text-zinc-400 mb-3">
                  <strong class="text-zinc-200 font-medium">{name}</strong> is a Japanese visual artist, compositor, and motion designer.
                  He is primarily active as a director for music videos, focusing on illustration-based visual works.
                  A member of the creative collective <a href="https://corecreative.jp/" target="_blank" class="text-zinc-300 hover:text-white underline underline-offset-4 decoration-zinc-700 transition-all hover:scale-105 inline-block origin-left">Core Creative</a> and the musical unit <a href="https://x.com/CDs_inter" target="_blank" class="text-zinc-300 hover:text-white underline underline-offset-4 decoration-zinc-700 transition-all hover:scale-105 inline-block origin-left">CDs</a>.
                </p>
                <p class="text-zinc-600 italic">
                  藤白 詩集（ふじしろ・ししゅう、生年不明）は、日本の映像作家、コンポジター、モーションデザイナー。
                  主にイラストレーションを中心としたミュージックビデオを手掛けている。クリエイティブ・コレクティブ「<a href="https://corecreative.jp/" target="_blank" class="hover:text-zinc-400 underline underline-offset-4 decoration-zinc-800 transition-all hover:scale-105 inline-block origin-left">Core Creative</a>」およびレーベル「<a href="https://x.com/CDs_inter" target="_blank" class="hover:text-zinc-400 underline underline-offset-4 decoration-zinc-800 transition-all hover:scale-105 inline-block origin-left">CDs</a>」のメンバー
                </p>
              </div>
            </div> 
          </div>

          <div class="flex flex-wrap gap-3 text-[10px] tracking-[0.2em] uppercase">
            {snsLinks.map(link => (
              <a href={link.url} target="_blank" class="border border-zinc-800 px-5 py-2 hover:bg-[#d0e2f8] hover:text-black hover:border-[#d0e2f8] transition-all duration-300 hover:scale-110 origin-center">
                {link.name}
              </a>
            ))}
          </div>
        </section>

        <div class="grid lg:grid-cols-2 gap-24 items-start">
          <section>
            <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-400 uppercase mb-6 border-b border-zinc-900 pb-2">Recent Logs</h2>
            <div id="rotary" class="rotary-viewport">
              <div id="rotary-list" class="flex flex-col">
                {logs.map((log) => (
                  <div class="rotary-item group">
                    <div class="flex gap-4 items-center">
                      <div class="h-1.5 w-1.5 rounded-full bg-[#d0e2f8] shadow-[0_0_8px_rgba(208,226,248,0.4)] group-hover:shadow-[0_0_12px_rgba(208,226,248,0.8)] transition-all"></div>
                      <div>
                        <div class="text-[10px] font-mono text-zinc-400 mb-1 tracking-wider">{log.date}</div>
                        <a href={log.url} target="_blank" class="text-sm tracking-wider text-zinc-300 group-hover:text-[#d0e2f8] transition-all hover:scale-105 origin-left inline-block">{log.content}</a>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="space-y-20">
            <div>
              <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-600 uppercase mb-10 border-b border-zinc-900 pb-2">Work Scope</h2>
              <div class="space-y-6">
                {workScope.map(work => (
                  <div>
                    <h3 class="text-sm font-bold text-zinc-200">{work.title}</h3>
                    <p class="text-xs text-zinc-500 mt-1">{work.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-600 uppercase mb-10 border-b border-zinc-900 pb-2">Direct Link</h2>
              <a href="https://lime479000.studio.site/about" target="_blank" class="block group p-6 bg-zinc-950 border border-zinc-900 hover:border-zinc-500 transition-all hover:scale-[1.02] origin-center mb-4">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-white font-bold tracking-widest uppercase">Go to Studio Site</span>
                  <span class="text-xl group-hover:translate-x-2 transition-transform">→</span>
                </div>
                <p class="text-[10px] text-zinc-500 mt-2">Click for more project details and showreel.</p>
              </a>
              <a href="https://corecreative.jp/shishu-fujishiro" target="_blank" class="block group p-6 bg-zinc-950 border border-zinc-900 hover:border-zinc-500 transition-all hover:scale-[1.02] origin-center">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-white font-bold tracking-widest uppercase">Core Creative Profile</span>
                  <span class="text-xl group-hover:translate-x-2 transition-transform">→</span>
                </div>
                <p class="text-[10px] text-zinc-500 mt-2">View professional works and creative collective details.</p>
              </a>
            </div>
          </section>
        </div>
      </main>

      <footer class="mt-40 pt-10 border-t border-zinc-900 flex justify-between items-center text-[10px] font-mono text-zinc-500 italic">
        <div>AFFILIATION: CORE CREATIVE / CDs</div>
        <div>{email}</div>
      </footer>
    </div>

    <script>
      // --- Cursor Follower logic ---
      const light = document.getElementById('cursor-light');
      window.addEventListener('mousemove', (e) => {
        if (light) {
          light.style.left = `${e.clientX}px`;
          light.style.top = `${e.clientY}px`;
        }
      });

      // --- Rotary logic ---
      const rotary = document.getElementById('rotary') as HTMLElement;
      const list = document.getElementById('rotary-list') as HTMLElement;
      const items = Array.from(list.children);
      const itemHeight = 80;

      items.forEach(item => list.appendChild(item.cloneNode(true)));
      items.forEach(item => list.insertBefore(item.cloneNode(true), list.firstChild));
      rotary.scrollTop = items.length * itemHeight;

      let isInteracting = false;
      rotary.addEventListener('mousedown', () => isInteracting = true);
      window.addEventListener('mouseup', () => isInteracting = false);
      rotary.addEventListener('touchstart', () => isInteracting = true);
      window.addEventListener('touchend', () => isInteracting = false);
      rotary.addEventListener('wheel', () => {
        isInteracting = true;
        clearTimeout((rotary as any).wheelTimer);
        (rotary as any).wheelTimer = setTimeout(() => isInteracting = false, 1000);
      });

      function updateRotary() {
        if (rotary.scrollTop <= 0) rotary.scrollTop = items.length * itemHeight;
        else if (rotary.scrollTop >= items.length * itemHeight * 2) rotary.scrollTop = items.length * itemHeight;
        if (!isInteracting) rotary.scrollTop += 0.4;
        requestAnimationFrame(updateRotary);
      }
      updateRotary();

      // --- Meta logic ---
      window.addEventListener('load', () => {
        const loadEl = document.getElementById('load-time');
        if(loadEl) loadEl.innerText = `LOAD: ${Math.round(performance.now())}ms`;
      });
      setInterval(() => {
        const timeEl = document.getElementById('sys-time');
        if(timeEl) timeEl.innerText = `TIME: ${new Date().toLocaleTimeString('ja-JP', { hour12: false })} JST`;
      }, 1000);
    </script>
  </body>
</html>
