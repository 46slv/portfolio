---
import '../styles/global.css';

const name = "Shishu Fujishiro"; [cite: 1]
const jpName = "藤白 詩集"; [cite: 1]
const roles = "Compositor / Colorist / Motion Designer / Cinematographer"; [cite: 2]
const email = "info@corecreative.jp"; [cite: 2]

const snsLinks = [
  { name: "X (Twitter)", url: "https://x.com/shiro_works" }, [cite: 3]
];

const logs = [
  { date: "2025.12.21.", content: "V/R Converters「ニューラルへ縹緲」オフィシャルリリックブック", url: "https://x.com/shiro_works/status/2003103881790914873?s=20" }, [cite: 4]
  { date: "2025.12.12.", content: "【 # 4 生演奏歌枠 】manuscript / 綿菓子かんろ", url: "https://x.com/Wata_kanro/status/1999463442328224198?s=20" }, [cite: 4]
  { date: "2025.09.01.", content: "Core Creative 加入 / CDs 加入 / 名義追加", url: "https://x.com/shiro_works/status/1962168505782186124?s=20" }, [cite: 4]
  { date: "2025.08.22.", content: "【#3 生演奏歌枠】常夏ノ夜ニ萌ユ！", url: "https://x.com/Wata_kanro/status/1958875429101871257?s=20" }, [cite: 4]
  { date: "2025.08.16.", content: "【歌ってみた】空想フォレスト / 綿菓子かんろ", url: "https://x.com/Wata_kanro/status/1956371845164253453?s=20" }, [cite: 4]
  { date: "2025.07.25.", content: "【歌ってみた】サンフェーデッド / 綿菓子かんろ", url: "https://x.com/shiro_works/status/1961069976883782057?s=20." }, [cite: 4]
  { date: "2025.03.06.", content: "【歌ってみた】きゅびずむ / 綿菓子かんろ", url: "https://x.com/Wata_kanro/status/1897624776644124810?s=20" }, [cite: 5]
];

const workScope = [
  { title: "Music Video", desc: "Filmmaking / Editing / Motion Graphics" }, [cite: 6]
  { title: "Film Instructor", desc: "Support Lecturer at Vocational School" }, [cite: 6]
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SS_Portfolio | {name}</title> [cite: 8]
    <style is:global>
      @keyframes fadeSlideRight {
        0% { opacity: 0; transform: translateX(-15px); } [cite: 9]
        100% { opacity: 1; transform: translateX(0); } [cite: 10]
      }
      .animate-fade-slide {
        opacity: 0; [cite: 10]
        animation: fadeSlideRight 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; [cite: 11]
      }
      .delay-100 { animation-delay: 100ms; } [cite: 11]
      .delay-200 { animation-delay: 200ms; } [cite: 12]
      .delay-300 { animation-delay: 300ms; } [cite: 12]
      .delay-400 { animation-delay: 400ms; } [cite: 13]
      .delay-500 { animation-delay: 500ms; } [cite: 13]

      /* --- Rotary Setting (Updated for Freewheel) --- */
      .rotary-viewport {
        height: 320px; [cite: 14]
        overflow-y: auto; [cite: 15]
        /* スナップをJSで制御するためCSS側はOFFにする */
        scroll-snap-type: none; 
        -webkit-overflow-scrolling: touch; /* iOSでの慣性スクロール有効化 */
        scrollbar-width: thin; [cite: 15]
        scrollbar-color: #3f3f46 transparent; 
        mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent); [cite: 15]
      }
      .rotary-viewport::-webkit-scrollbar { width: 2px; } [cite: 16]
      .rotary-viewport::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 2px; }
      
      .rotary-item { 
        height: 80px; [cite: 17]
        display: flex; 
        align-items: center; 
      }

      .focus-container:has(a:hover) .dim-text { opacity: 0.3; } [cite: 17]
      .dim-text { transition: opacity 0.4s ease; } [cite: 18]

      #cursor-light {
        width: 150px; [cite: 19]
        height: 150px; [cite: 20]
        background: radial-gradient(circle, rgba(208,226,248,0.15) 0%, transparent 70%); [cite: 20]
        border-radius: 50%; [cite: 20]
        position: fixed; [cite: 20]
        pointer-events: none; [cite: 20]
        z-index: 9999; [cite: 20]
        transform: translate(-50%, -50%); [cite: 20]
        mix-blend-mode: screen; [cite: 21]
        transition: transform 0.1s ease-out; [cite: 21]
        display: none; [cite: 21]
      }
      @media (hover: hover) { #cursor-light { display: block; } } [cite: 22]
    </style>
  </head>
  <body class="bg-[#0a0a0a] text-[#a1a1a1] font-sans selection:bg-white selection:text-black antialiased overflow-x-hidden">
    
    <div id="cursor-light"></div>

    <div class="max-w-6xl mx-auto p-6 md:p-16 lg:p-24 min-h-screen flex flex-col relative z-10">
      <header class="flex justify-between items-start mb-32 animate-fade-slide"> [cite: 22]
        <div class="text-[10px] tracking-[0.4em] font-black text-white uppercase opacity-50">SS_Portfolio v2.4</div> [cite: 22]
        <div class="text-[10px] tracking-widest uppercase font-mono text-right space-y-1"> [cite: 22]
          <div>Status: <span class="text-green-500 animate-pulse">ONLINE</span></div> [cite: 23]
          <div id="sys-time" class="text-zinc-500">TIME: --:--:--</div> [cite: 23]
          <div id="load-time" class="text-zinc-600">LOAD: ---ms</div> [cite: 23]
        </div>
      </header>

      <main class="flex-grow">
        <section class="mb-24"> [cite: 24]
          <div class="border-b border-zinc-900 pb-8 mb-12 animate-fade-slide delay-100"> [cite: 24]
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 transition-all duration-700 hover:tracking-widest cursor-default">
              {name} [cite: 24]
              <span class="text-zinc-600 font-light text-xl md:text-2xl italic ml-4 tracking-normal">{jpName}</span> [cite: 24]
            </h1>
            <div class="focus-container space-y-8 text-sm md:text-base leading-loose max-w-3xl font-light"> [cite: 25]
              <p class="text-zinc-400">
                <span class="dim-text">
                  <strong class="text-zinc-200 font-medium">{name}</strong> is a Japanese visual artist, compositor, and motion designer. [cite: 25]
                  He is primarily active as a director for music videos, focusing on illustration-based visual works. [cite: 26]
                  A member of the creative collective [cite: 27]
                </span>
                <a href="https://corecreative.jp/" target="_blank" class="text-zinc-300 hover:text-white underline underline-offset-4 decoration-zinc-700 transition-all hover:scale-105 inline-block origin-left">Core Creative</a> [cite: 27, 28]
                <span class="dim-text">and the musical unit</span> [cite: 28, 29]
                <a href="https://x.com/CDs_inter" target="_blank" class="text-zinc-300 hover:text-white underline underline-offset-4 decoration-zinc-700 transition-all hover:scale-105 inline-block origin-left">CDs</a> [cite: 29, 30]
                <span class="dim-text">.</span> [cite: 30]
              </p>
              <p class="text-zinc-600 italic"> [cite: 30]
                <span class="dim-text">藤白 詩集（ふじしろ・ししゅう、生年不明）は、日本の映像作家、コンポジター、モーションデザイナー。主にイラストレーションを中心としたミュージックビデオを手掛けている。クリエイティブ・コレクティブ「</span> [cite: 31]
                <a href="https://corecreative.jp/" target="_blank" class="hover:text-zinc-400 underline underline-offset-4 decoration-zinc-800 transition-all hover:scale-105 inline-block origin-left">Core Creative</a> [cite: 32]
                <span class="dim-text">」およびレーベル「</span> [cite: 33]
                <a href="https://x.com/CDs_inter" target="_blank" class="hover:text-zinc-400 underline underline-offset-4 decoration-zinc-800 transition-all hover:scale-105 inline-block origin-left">CDs</a> [cite: 33, 34]
                <span class="dim-text">」のメンバー。</span> [cite: 34]
              </p>
            </div> 
          </div>

          <div class="animate-fade-slide delay-200"> [cite: 35]
            <div class="mb-4 space-y-1"> [cite: 35]
              <p class="text-xs text-zinc-500 font-light tracking-wide">お仕事のご依頼やお問い合わせはこちらまで</p> [cite: 35]
              <p class="text-[10px] text-zinc-600 uppercase tracking-widest">Please feel free to contact me for any inquiries.</p> [cite: 36]
            </div>
            <div class="flex flex-wrap gap-3 text-[10px] tracking-[0.2em] uppercase"> [cite: 37]
              {snsLinks.map(link => ( [cite: 37]
                <a href={link.url} target="_blank" class="border border-zinc-800 px-5 py-3 hover:bg-[#d0e2f8] hover:text-black hover:border-[#d0e2f8] transition-all duration-300 hover:scale-105 origin-center flex items-center">
                  {link.name} [cite: 38, 39]
                </a> [cite: 39]
              ))}
              <button id="copy-email-btn" class="group relative border border-zinc-800 px-5 py-3 hover:bg-[#d0e2f8] hover:text-black hover:border-[#d0e2f8] transition-all duration-300 hover:scale-105 origin-center cursor-pointer flex items-center gap-2" data-email={email}> [cite: 39, 40]
                <span>Mail: {email}</span> [cite: 40]
                <span id="copy-tooltip" class="absolute -top-8 left-1/2 -translate-x-1/2 bg-white text-black px-3 py-1 text-[8px] font-bold opacity-0 transition-opacity pointer-events-none before:content-[''] before:absolute before:top-full before:left-1/2 before:-translate-x-1/2 before:border-4 before:border-transparent before:border-t-white">COPIED!</span> [cite: 41, 42]
              </button>
            </div>
          </div>
        </section>

        <div class="grid lg:grid-cols-2 gap-24 items-start"> [cite: 42]
          <section class="animate-fade-slide delay-300"> [cite: 42]
            <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-400 uppercase mb-6 border-b border-zinc-900 pb-2">Recent Logs</h2> [cite: 43]
            <div id="rotary" class="rotary-viewport"> [cite: 43]
              <div id="rotary-list" class="flex flex-col"> [cite: 43]
                {logs.map((log) => ( [cite: 43]
                  <div class="rotary-item group"> [cite: 43]
                    <div class="flex gap-4 items-center"> [cite: 44]
                      <div class="h-1.5 w-1.5 rounded-full bg-[#d0e2f8] shadow-[0_0_8px_rgba(208,226,248,0.4)] group-hover:shadow-[0_0_12px_rgba(208,226,248,0.8)] transition-all"></div> [cite: 44]
                      <div>
                        <div class="text-[10px] font-mono text-zinc-400 mb-1 tracking-wider">{log.date}</div> [cite: 44, 45]
                        <a href={log.url} target="_blank" class="text-sm tracking-wider text-zinc-300 group-hover:text-[#d0e2f8] transition-all hover:scale-105 origin-left inline-block">{log.content}</a> [cite: 45, 46]
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="space-y-20 animate-fade-slide delay-400"> [cite: 48]
            <div>
              <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-600 uppercase mb-10 border-b border-zinc-900 pb-2">Work Scope</h2> [cite: 48]
              <div class="space-y-6"> [cite: 49]
                {workScope.map(work => ( [cite: 49]
                  <div>
                    <h3 class="text-sm font-bold text-zinc-200">{work.title}</h3> [cite: 49]
                    <p class="text-xs text-zinc-500 mt-1">{work.desc}</p> [cite: 49]
                  </div>
                ))}
              </div>
            </div>
            <div>
              <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-600 uppercase mb-10 border-b border-zinc-900 pb-2">Direct Link</h2> [cite: 50, 51]
              <a href="https://lime479000.studio.site/about" target="_blank" class="block group p-6 bg-zinc-950 border border-zinc-900 hover:border-zinc-500 transition-all hover:scale-[1.02] origin-center mb-4"> [cite: 51]
                <div class="flex justify-between items-center"> [cite: 52]
                  <span class="text-sm text-white font-bold tracking-widest uppercase">Go to Studio Site</span> [cite: 52]
                  <span class="text-xl group-hover:translate-x-2 transition-transform">→</span> [cite: 52]
                </div>
                <p class="text-[10px] text-zinc-500 mt-2">old site.</p> [cite: 53]
              </a>
              <a href="https://corecreative.jp/shishu-fujishiro" target="_blank" class="block group p-6 bg-zinc-950 border border-zinc-900 hover:border-zinc-500 transition-all hover:scale-[1.02] origin-center"> [cite: 53, 54]
                <div class="flex justify-between items-center"> [cite: 54]
                  <span class="text-sm text-white font-bold tracking-widest uppercase">Core Creative Profile</span> [cite: 54]
                  <span class="text-xl group-hover:translate-x-2 transition-transform">→</span> [cite: 54]
                </div>
                <p class="text-[10px] text-zinc-500 mt-2">View professional works and creative collective details.</p> [cite: 55]
              </a>
            </div>
          </section>
        </div>
      </main>

      <footer class="mt-40 pt-10 border-t border-zinc-900 flex justify-between items-center text-[10px] font-mono text-zinc-500 italic animate-fade-slide delay-500"> [cite: 55]
        <div>AFFILIATION: CORE CREATIVE / CDs</div> [cite: 56]
        <div>{email}</div> [cite: 56]
      </footer>
    </div>

    <script>
      // --- Copy Email ---
      const copyBtn = document.getElementById('copy-email-btn'); [cite: 56]
      const copyTooltip = document.getElementById('copy-tooltip'); [cite: 57]
      if (copyBtn && copyTooltip) {
        copyBtn.addEventListener('click', async () => {
          const emailAddress = copyBtn.getAttribute('data-email');
          if (!emailAddress) return;
          try {
            await navigator.clipboard.writeText(emailAddress);
            copyTooltip.style.opacity = '1'; [cite: 57]
            setTimeout(() => { copyTooltip.style.opacity = '0'; }, 2000); [cite: 58]
          } catch (err) { console.error('Failed to copy: ', err); }
        });
      }

      // --- Cursor Light ---
      const light = document.getElementById('cursor-light'); [cite: 59]
      window.addEventListener('mousemove', (e) => {
        if (light) {
          light.style.left = `${e.clientX}px`; [cite: 60]
          light.style.top = `${e.clientY}px`; [cite: 60]
        }
      });

      // --- Rotary logic (Freewheel & Auto-Snap) ---
      const rotary = document.getElementById('rotary') as HTMLElement; [cite: 61]
      const list = document.getElementById('rotary-list') as HTMLElement; [cite: 62]
      
      if (rotary && list) {
        const originalItems = Array.from(list.children); [cite: 62]
        const itemHeight = 80; [cite: 63]
        const totalHeight = originalItems.length * itemHeight;

        // リストを3倍にして無限化
        originalItems.forEach(item => list.appendChild(item.cloneNode(true))); [cite: 63]
        originalItems.forEach(item => list.insertBefore(item.cloneNode(true), list.firstChild)); [cite: 63]
        rotary.scrollTop = totalHeight; [cite: 63]

        let isInteracting = false; [cite: 63]
        let snapTimeout: number;

        // シームレスなワープ判定（スクロール中も実行）
        const handleLoop = () => {
          const current = rotary.scrollTop;
          // 上端(コピー領域の半分)まで行ったら中央へ飛ばす
          if (current <= itemHeight * 2) {
            rotary.scrollTop = current + totalHeight;
          } 
          // 下端まで行ったら中央へ飛ばす
          else if (current >= totalHeight * 2 + itemHeight * 2) {
            rotary.scrollTop = current - totalHeight;
          }
        };

        // スナップ処理
        const snapToCenter = () => {
          if (isInteracting) return;
          
          const current = rotary.scrollTop;
          // 中央のセクション内での相対位置から、最も近いアイテムのインデックスを計算
          const targetIndex = Math.round(current / itemHeight);
          rotary.scrollTo({
            top: targetIndex * itemHeight,
            behavior: 'smooth'
          });
        };

        rotary.addEventListener('scroll', () => {
          handleLoop();
          
          // スクロールが止まったら500ms後にスナップを開始
          clearTimeout(snapTimeout);
          if (!isInteracting) {
            snapTimeout = window.setTimeout(snapToCenter, 500);
          }
        }, { passive: true });

        // インタラクション管理
        const startInteraction = () => {
          isInteracting = true;
          clearTimeout(snapTimeout);
        };
        const endInteraction = () => {
          isInteracting = false;
          snapTimeout = window.setTimeout(snapToCenter, 500);
        };

        rotary.addEventListener('mousedown', startInteraction); [cite: 64]
        window.addEventListener('mouseup', endInteraction); [cite: 64]
        rotary.addEventListener('touchstart', startInteraction); [cite: 64]
        window.addEventListener('touchend', endInteraction); [cite: 65]
        rotary.addEventListener('wheel', () => {
          startInteraction();
          clearTimeout((rotary as any).wheelTimer);
          (rotary as any).wheelTimer = setTimeout(endInteraction, 100);
        }, { passive: true });

        // 自動の超微動（操作していない時のみ）
        function autoDrift() {
          if (!isInteracting) {
            // スナップ待ちの最中などは動かさない（競合防止）
            // ここでは純粋な自動スクロールではなく、静止時の味付け
            // rotary.scrollTop += 0.2; // 必要なら有効化
          }
          requestAnimationFrame(autoDrift); [cite: 67]
        }
        autoDrift(); [cite: 68]
      }

      window.addEventListener('load', () => {
        const loadEl = document.getElementById('load-time'); [cite: 68]
        if(loadEl) loadEl.innerText = `LOAD: ${Math.round(performance.now())}ms`; [cite: 68]
      });
      setInterval(() => {
        const timeEl = document.getElementById('sys-time'); [cite: 69]
        if(timeEl) timeEl.innerText = `TIME: ${new Date().toLocaleTimeString('ja-JP', { hour12: false })} JST`; [cite: 69]
      }, 1000);
    </script>
  </body>
</html>
