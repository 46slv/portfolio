---
import '../styles/global.css';

// SS_Portfolio Data
const name = "Shishu Fujishiro";
const jpName = "藤白 詩集";
const roles = "Compositor / Colorist / Motion Designer / Cinematographer";
const email = "info@corecreative.jp";

const snsLinks = [
  { name: "X (Twitter)", url: "https://x.com/shiro_works" },
];

const logs = [

  { 
    date: "2025.12.21.", 
    content: "V/R Converters「ニューラルへ縹緲」オフィシャルリリックブック",
    url: "https://x.com/shiro_works/status/2003103881790914873?s=20" 
  },
  { 
    date: "2025.12.12.", 
    content: "【 # 4 生演奏歌枠 】manuscript / 綿菓子かんろ",
    url: "https://x.com/Wata_kanro/status/1999463442328224198?s=20" 
  },
  { 
    date: "2025.09.01", 
    content: "Core Creative 加入 / CDs 加入 / 名義追加",
    url: "https://x.com/shiro_works/status/1962168505782186124?s=20" // 飛ばしたいURLをここへ
  },
  { 
    date: "2025.08.22", 
    content: "【#3 生演奏歌枠】常夏ノ夜ニ萌ユ！",
    url: "https://x.com/Wata_kanro/status/1958875429101871257?s=20" 
  },
  { 
    date: "2025.08.16", 
    content: "【歌ってみた】空想フォレスト / 綿菓子かんろ",
    url: "https://x.com/Wata_kanro/status/1956371845164253453?s=20"
  },
  { 
    date: "2025.07.25", 
    content: "【歌ってみた】サンフェーデッド / 綿菓子かんろ",
    url: "https://x.com/shiro_works/status/1961069976883782057?s=20."
  },
  { 
    date: "2025.05.28", 
    content: "【歌ってみた】きゅびびびびびびびびびびびびびびびびびびびびびびびびずむ / 綿菓子かんろ",
    url: "https://x.com/Wata_kanro/status/1927654765754003841?s=20"

  },
  { 
    date: "2025.05.28", 
    content: "【歌ってみた】きゅびびびびずむ / 綿菓子かんろ",
    url: "https://x.com/Wata_kanro/status/1927654765754003841?s=20"
  },
  { 
    date: "2025.03.06", 
    content: "【歌ってみた】きゅびずむ / 綿菓子かんろ",
    url: "https://x.com/Wata_kanro/status/1897624776644124810?s=20"
  },

];
const workScope = [
  { title: "Music Video", desc: "Filmmaking / Editing / Motion Graphics" },
  { title: "Film Instructor", desc: "Support Lecturer at Vocational School" },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SS_Portfolio | {name}</title>
    <style is:global>
      /* --- Load Animation --- */
      @keyframes fadeSlideRight {
        0% { opacity: 0; transform: translateX(-15px); }
        100% { opacity: 1; transform: translateX(0); }
      }
      .animate-fade-slide {
        opacity: 0;
        animation: fadeSlideRight 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      }
      .delay-100 { animation-delay: 100ms; }
      .delay-200 { animation-delay: 200ms; }
      .delay-300 { animation-delay: 300ms; }
      .delay-400 { animation-delay: 400ms; }
      .delay-500 { animation-delay: 500ms; }

      /* --- Rotary Setting (Ghost Scroll Method) --- */
      .rotary-viewport {
        /* ネイティブ慣性スクロールを有効化 */
        -webkit-overflow-scrolling: touch; 
        scrollbar-width: thin;
        scrollbar-color: #3f3f46 transparent; 
      }
      .rotary-viewport::-webkit-scrollbar { width: 2px; }
      .rotary-viewport::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 2px; }
      
      .rotary-item { 
        height: 80px;
        display: flex; 
        align-items: center; 
        top: 0;
        /* GPUレンダリングを強制して滑らかに */
        will-change: transform; 
      }

      /* --- Focus Dim Effect --- */
      .focus-container:has(a:hover) .dim-text { opacity: 0.3; }
      .dim-text { transition: opacity 0.4s ease; }

      /* --- Cursor Follower --- */
      #cursor-light {
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, rgba(208,226,248,0.15) 0%, transparent 70%);
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        mix-blend-mode: screen;
        transition: transform 0.1s ease-out;
        display: none;
      }
      @media (hover: hover) { #cursor-light { display: block; } }
    </style>
  </head>
  <body class="bg-[#0a0a0a] text-[#a1a1a1] font-sans selection:bg-white selection:text-black antialiased overflow-x-hidden">
    
    <div id="cursor-light"></div>

    <div class="max-w-6xl mx-auto p-6 md:p-16 lg:p-24 min-h-screen flex flex-col relative z-10">
      
      <header class="flex justify-between items-start mb-12 animate-fade-slide">
        <div class="text-[10px] tracking-[0.4em] font-black text-white uppercase opacity-50">SS_Portfolio v2.05</div>
        <div class="text-[10px] tracking-widest uppercase font-mono text-right space-y-1">
          <div>Status: <span class="text-green-500 animate-pulse">ONLINE</span></div>
          <div id="sys-time" class="text-zinc-500">TIME: --:--:--</div>
          <div id="load-time" class="text-zinc-600">LOAD: ---ms</div>
        </div>
      </header>

      <main class="flex-grow">
        <section class="mb-24">
          <div class="border-b border-zinc-900 pb-8 mb-12 animate-fade-slide delay-100">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 transition-all duration-700 hover:tracking-widest cursor-default">
              {name}
              <span class="text-zinc-600 font-light text-xl md:text-2xl italic ml-4 tracking-normal">{jpName}</span>
            </h1>

            <div class="focus-container space-y-8 text-sm md:text-base leading-loose max-w-3xl font-light">
              <p class="text-zinc-400">
                <span class="dim-text">
                  <strong class="text-zinc-200 font-medium">{name}</strong> is a Japanese visual artist, compositor, and motion designer.
                  He is primarily active as a director for music videos, focusing on illustration-based visual works.
                  A member of the creative collective
                </span>
                <a href="https://corecreative.jp/" target="_blank" class="text-zinc-300 hover:text-white underline underline-offset-4 decoration-zinc-700 transition-all hover:scale-105 inline-block origin-left">Core Creative</a>
                <span class="dim-text">and the musical unit</span>
                <a href="https://x.com/CDs_inter" target="_blank" class="text-zinc-300 hover:text-white underline underline-offset-4 decoration-zinc-700 transition-all hover:scale-105 inline-block origin-left">CDs</a>
                <span class="dim-text">.</span>
              </p>
              <p class="text-zinc-600 italic">
                <span class="dim-text">藤白 詩集（ふじしろ・ししゅう、生年不明）は、日本の映像作家、コンポジター、モーションデザイナー。主にイラストレーションを中心としたミュージックビデオを手掛けている。クリエイティブ・コレクティブ「</span>
                <a href="https://corecreative.jp/" target="_blank" class="hover:text-zinc-400 underline underline-offset-4 decoration-zinc-800 transition-all hover:scale-105 inline-block origin-left">Core Creative</a>
                <span class="dim-text">」およびレーベル「</span>
                <a href="https://x.com/CDs_inter" target="_blank" class="hover:text-zinc-400 underline underline-offset-4 decoration-zinc-800 transition-all hover:scale-105 inline-block origin-left">CDs</a>
                <span class="dim-text">」のメンバー。</span>
              </p>
            </div> 
          </div>

          <div class="animate-fade-slide delay-200">
            <div class="mb-4 space-y-1">
              <p class="text-xs text-zinc-500 font-light tracking-wide">お仕事のご依頼やお問い合わせはこちらまで</p>
              <p class="text-[10px] text-zinc-600 uppercase tracking-widest">Please feel free to contact me for any inquiries.</p>
            </div>
            
            <div class="flex flex-wrap gap-3 text-[10px] tracking-[0.2em] uppercase">
              {snsLinks.map(link => (
                <a href={link.url} target="_blank" class="border border-zinc-800 px-5 py-3 hover:bg-[#d0e2f8] hover:text-black hover:border-[#d0e2f8] transition-all duration-300 hover:scale-105 origin-center flex items-center">
                  {link.name}
                </a>
              ))}
              
              <button id="copy-email-btn" class="group relative border border-zinc-800 px-5 py-3 hover:bg-[#d0e2f8] hover:text-black hover:border-[#d0e2f8] transition-all duration-300 hover:scale-105 origin-center cursor-pointer flex items-center gap-2" data-email={email}>
                <span>Mail: {email}</span>
                <span id="copy-tooltip" class="absolute -top-8 left-1/2 -translate-x-1/2 bg-white text-black px-3 py-1 text-[8px] font-bold opacity-0 transition-opacity pointer-events-none before:content-[''] before:absolute before:top-full before:left-1/2 before:-translate-x-1/2 before:border-4 before:border-transparent before:border-t-white">
                  COPIED!
                </span>
              </button>
            </div>
          </div>
        </section>

        <div class="grid lg:grid-cols-2 gap-24 items-start">
          
          <section class="animate-fade-slide delay-300">
            <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-400 uppercase mb-6 border-b border-zinc-900 pb-2">Recent Logs</h2>
            
            <div class="relative h-[320px]" style="mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);">
              
              <div id="rotary" class="rotary-viewport absolute inset-0 overflow-y-auto">
                <div id="rotary-dummy" style="height: 100000px;"></div>
                <div id="rotary-list" class="absolute top-0 left-0 w-full">
                  {logs.map((log) => (
                    <div class="rotary-item absolute w-full">
                      <div class="flex gap-4 items-center group">
                        <div class="h-1.5 w-1.5 rounded-full bg-[#d0e2f8] shadow-[0_0_8px_rgba(208,226,248,0.4)] group-hover:shadow-[0_0_12px_rgba(208,226,248,0.8)] transition-all"></div>
                        <div>
                          <div class="text-[10px] font-mono text-zinc-400 mb-1 tracking-wider">{log.date}</div>
                          <a href={log.url} target="_blank" class="text-sm tracking-wider text-zinc-300 group-hover:text-[#d0e2f8] transition-all hover:scale-105 origin-left inline-block">
                            {log.content}
                          </a>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </section>

          <section class="space-y-20 animate-fade-slide delay-400">
            <div>
              <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-600 uppercase mb-10 border-b border-zinc-900 pb-2">Work Scope</h2>
              <div class="space-y-6">
                {workScope.map(work => (
                  <div>
                    <h3 class="text-sm font-bold text-zinc-200">{work.title}</h3>
                    <p class="text-xs text-zinc-500 mt-1">{work.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h2 class="text-[10px] tracking-[0.3em] font-bold text-zinc-600 uppercase mb-10 border-b border-zinc-900 pb-2">Direct Link</h2>
              <a href="https://lime479000.studio.site/about" target="_blank" class="block group p-6 bg-zinc-950 border border-zinc-900 hover:border-zinc-500 transition-all hover:scale-[1.02] origin-center mb-4">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-white font-bold tracking-widest uppercase">Go to Studio Site</span>
                  <span class="text-xl group-hover:translate-x-2 transition-transform">→</span>
                </div>
                <p class="text-[10px] text-zinc-500 mt-2">old site.</p>
              </a>
              <a href="https://corecreative.jp/shishu-fujishiro" target="_blank" class="block group p-6 bg-zinc-950 border border-zinc-900 hover:border-zinc-500 transition-all hover:scale-[1.02] origin-center">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-white font-bold tracking-widest uppercase">Core Creative Profile</span>
                  <span class="text-xl group-hover:translate-x-2 transition-transform">→</span>
                </div>
                <p class="text-[10px] text-zinc-500 mt-2">View professional works and creative collective details.</p>
              </a>
            </div>
          </section>
        </div>
      </main>

      <footer class="mt-40 pt-10 border-t border-zinc-900 flex justify-between items-center text-[10px] font-mono text-zinc-500 italic animate-fade-slide delay-500">
        <div>AFFILIATION: CORE CREATIVE / CDs</div>
        <div>{email}</div>
      </footer>
    </div>

    <script>
      // --- Copy Email ---
      const copyBtn = document.getElementById('copy-email-btn');
      const copyTooltip = document.getElementById('copy-tooltip');
      if (copyBtn && copyTooltip) {
        copyBtn.addEventListener('click', async () => {
          const emailAddress = copyBtn.getAttribute('data-email');
          if (!emailAddress) return;
          try {
            await navigator.clipboard.writeText(emailAddress);
            copyTooltip.style.opacity = '1';
            setTimeout(() => { copyTooltip.style.opacity = '0'; }, 2000);
          } catch (err) { console.error('Failed to copy: ', err); }
        });
      }

      // --- Cursor Light ---
      const light = document.getElementById('cursor-light');
      window.addEventListener('mousemove', (e) => {
        if (light) {
          light.style.left = `${e.clientX}px`;
          light.style.top = `${e.clientY}px`;
        }
      });

      // --- Rotary Logic (Modulo Transform & Ghost Scroll) ---
      const rotary = document.getElementById('rotary') as HTMLElement;
      const list = document.getElementById('rotary-list') as HTMLElement;
      
      if (rotary && list) {
        const items = Array.from(list.children) as HTMLElement[];
        const itemHeight = 80;
        const totalHeight = items.length * itemHeight;
        
        // テレポートする境界線のオフセット（画面外）
        const offset = itemHeight; 
        
        // 巨大なダミー要素の中央付近からスタート
        const centerPos = Math.floor(50000 / itemHeight) * itemHeight;
        rotary.scrollTop = centerPos;

        let isInteracting = false;
        let snapTimeout: number;

        // モジュロ計算でY座標を更新する
        const updateItems = () => {
          const currentScroll = rotary.scrollTop;
          // 中央からの移動量を計算
          const scrollY = currentScroll - centerPos;
          
          items.forEach((item, i) => {
            const basePos = i * itemHeight;
            const pos = basePos - scrollY;
            
            // 画面外上部（-80px）から画面外下部に到達したらループ
            const wrappedPos = (((pos + offset) % totalHeight) + totalHeight) % totalHeight - offset;
            
            item.style.transform = `translateY(${currentScroll + wrappedPos}px)`;
          });
        };

        // 静止後のスナップ処理
        const snapToCenter = () => {
          if (isInteracting) return;
          const current = rotary.scrollTop;
          // 最も近いアイテム（80pxの倍数）の座標へスムーススクロール
          const target = Math.round(current / itemHeight) * itemHeight;
          rotary.scrollTo({ top: target, behavior: 'smooth' });
        };

        rotary.addEventListener('scroll', () => {
          updateItems();
          
          clearTimeout(snapTimeout);
          // ユーザーが触っていない時だけスナップを開始（500ms後）
          if (!isInteracting) {
            snapTimeout = window.setTimeout(snapToCenter, 500);
          }
        }, { passive: true });

        // ユーザー操作の監視（スナップの競合を防ぐ）
        const startInteraction = () => {
          isInteracting = true;
          clearTimeout(snapTimeout);
        };
        const endInteraction = () => {
          isInteracting = false;
          clearTimeout(snapTimeout);
          snapTimeout = window.setTimeout(snapToCenter, 500);
        };

        rotary.addEventListener('mousedown', startInteraction);
        window.addEventListener('mouseup', endInteraction);
        rotary.addEventListener('touchstart', startInteraction);
        window.addEventListener('touchend', endInteraction);
        rotary.addEventListener('wheel', () => {
          startInteraction();
          clearTimeout((rotary as any).wheelTimer);
          (rotary as any).wheelTimer = setTimeout(endInteraction, 150);
        }, { passive: true });

        // 初回描画
        updateItems();
      }

      window.addEventListener('load', () => {
        const loadEl = document.getElementById('load-time');
        if(loadEl) loadEl.innerText = `LOAD: ${Math.round(performance.now())}ms`;
      });
      setInterval(() => {
        const timeEl = document.getElementById('sys-time');
        if(timeEl) timeEl.innerText = `TIME: ${new Date().toLocaleTimeString('ja-JP', { hour12: false })} JST`;
      }, 1000);
    </script>
  </body>
</html>
